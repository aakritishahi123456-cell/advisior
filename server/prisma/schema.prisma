enum ModelStatus {
  TRAINING
  TRAINED
  TESTING
  PRODUCTION
  ARCHIVED
  DELETED
  FAILED
}

enum ExperimentType {
  HYPERPARAMETER
  ARCHITECTURE
  FEATURE_ENGINEERING
  ENSEMBLE
}

enum ExperimentStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SentimentClassification {
  POSITIVE
  NEUTRAL
  NEGATIVE
}
