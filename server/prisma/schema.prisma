generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String               @map("password_hash")
  referralCode        String?              @unique @map("referral_code")
  plan                SubscriptionPlan     @default(FREE)
  planExpiry          DateTime?            @map("plan_expiry")
  firstName           String?              @map("first_name")
  lastName            String?              @map("last_name")
  phone               String?
  dateOfBirth         DateTime?            @map("date_of_birth")
  role                UserRole             @default(FREE)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  aiReports           AIReport[]
  apiUsageLogs        ApiUsageLog[]
  financialProfiles   FinancialProfile[]
  loanSimulations     LoanSimulation[]
  optimizedPortfolios OptimizedPortfolio[]
  portfolio           Portfolio?
  productAnalyticsEvents ProductAnalyticsEvent[]
  researchQueries     ResearchQuery[]
  referralsSent       Referral[]           @relation("ReferralInviter")
  referralReceived    Referral?            @relation("ReferralInvitee")
  rewards             Reward[]
  subscriptions       Subscription[]
  subscriptionLogs    SubscriptionLog[]
  transactions        Transaction[]
  userUsage           UserUsage[]
  usageTracking       UsageTracking[]

  @@map("users")
}

model Stock {
  id             String          @id @default(cuid())
  symbol         String          @unique
  name           String
  sector         String
  nepsePrices    NepsePrice[]
  portfolioItems PortfolioItem[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")

  @@index([symbol])
  @@map("stocks")
}

model UserUsage {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  month        String
  reportCount  Int      @default(0) @map("report_count")
  requestCount Int      @default(0) @map("request_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
  @@index([month])
  @@map("user_usage")
}

model ApiUsageLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String
  method    String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("api_usage_logs")
}

model ProductAnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  eventName  String   @map("event_name")
  category   String
  properties Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventName])
  @@index([category])
  @@index([createdAt])
  @@index([eventName, createdAt(sort: Desc)])
  @@map("product_analytics_events")
}

model Company {
  id                    String                   @id @default(cuid())
  symbol                String                   @unique
  name                  String
  sector                String
  listedYear            Int                      @map("listed_year")
  listedDate            DateTime?                @map("listed_date")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")
  aiReports             AIReport[]
  articleLinks          ArticleCompanyLink[]
  companyClassification CompanyClassification?
  companyDocuments      CompanyDocument[]
  dataQualityAnomalies  DataQualityAnomaly[]
  dataQualityAuditLogs  DataQualityAuditLog[]
  filings               Filing[]
  corporateActions      CorporateAction[]
  dividends             Dividend[]
  dividendHistory       DividendHistory[]
  extractedFacts        ExtractedFinancialFact[]
  financialReports      FinancialReport[]
  financialHistory      FinancialHistory[]
  nepseFinancials       NepseFinancial[]
  fiscalPeriods         FiscalPeriod[]
  newsSentiments        NewsSentiment[]
  portfolioAllocations  PortfolioAllocation[]
  priceHistory          PriceHistory[]
  nepsePrices           NepsePrice[]

  @@index([symbol])
  @@index([sector])
  @@map("companies")
}

model NepsePrice {
  id        String    @id @default(cuid())
  stockId   String    @map("stock_id")
  symbol    String?
  date      DateTime?
  price     Float
  change    Float     @default(0) @map("change_value")
  volume    BigInt?   @map("volume")
  timestamp DateTime  @default(now())
  open      Float?    @map("open")
  close     Float?    @map("close")
  high      Float?    @map("high")
  low       Float?    @map("low")
  source    String    @default("NEPSE")
  createdAt DateTime  @default(now()) @map("created_at")
  stock     Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([stockId, timestamp])
  @@index([timestamp])
  @@index([stockId])
  @@index([stockId, timestamp(sort: Desc)])
  @@map("prices")
}

model PriceHistory {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  symbol     String   @map("symbol")
  tradeDate  DateTime @map("trade_date")
  open       Float?   @map("open")
  high       Float?   @map("high")
  low        Float?   @map("low")
  close      Float    @map("close")
  price      Float    @map("price")
  change     Float?   @map("change_value")
  volume     BigInt?  @map("volume")
  source     String   @default("NEPSE")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, tradeDate])
  @@index([tradeDate])
  @@index([companyId])
  @@index([symbol])
  @@index([companyId, tradeDate(sort: Desc)])
  @@map("price_history")
}

model NepseFinancial {
  id            String   @id @default(cuid())
  symbol        String
  asOfDate      DateTime @map("as_of_date")
  eps           Float?   @map("eps")
  peRatio       Float?   @map("pe_ratio")
  marketCap     BigInt?  @map("market_cap")
  dividendYield Float?   @map("dividend_yield")
  revenue       Float?   @map("revenue")
  profit        Float?   @map("profit")
  assets        Float?   @map("assets")
  growthRate    Float?   @map("growth_rate")
  sourceDocument String? @map("source_document")
  source        String   @default("NEPSE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  company       Company  @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, asOfDate])
  @@index([symbol])
  @@index([asOfDate])
  @@map("financials")
}

model FinancialHistory {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  symbol      String   @map("symbol")
  fiscalYear  Int      @map("fiscal_year")
  reportDate  DateTime @map("report_date")
  revenue     Float?   @map("revenue")
  profit      Float?   @map("profit")
  eps         Float?   @map("eps")
  assets      Float?   @map("assets")
  liabilities Float?   @map("liabilities")
  source      String   @default("INTERNAL")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, fiscalYear])
  @@index([reportDate])
  @@index([companyId])
  @@index([symbol])
  @@index([companyId, reportDate(sort: Desc)])
  @@map("financial_history")
}

model FinancialReport {
  id          String     @id @default(cuid())
  companyId   String     @map("company_id")
  year        Int
  revenue     Float
  netProfit   Float      @map("net_profit")
  totalAssets Float      @map("total_assets")
  totalEquity Float      @map("total_equity")
  totalDebt   Float      @map("total_debt")
  createdAt   DateTime   @default(now()) @map("created_at")
  aiReports   AIReport[]
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([year])
  @@index([companyId, year])
  @@map("financial_reports")
}

model LoanSimulation {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  amount        Float
  rate          Float
  tenure        Int
  emi           Float
  totalInterest Float    @map("total_interest")
  totalPayment  Float    @map("total_payment")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([amount])
  @@index([rate])
  @@index([tenure])
  @@index([amount, rate, tenure])
  @@map("loan_simulations")
}

model AIReport {
  id                String           @id @default(cuid())
  userId            String           @map("user_id")
  companyId         String?          @map("company_id")
  financialReportId String?          @map("financial_report_id")
  year              Int?
  analysisText      String           @map("analysis_text")
  riskScore         Float            @map("risk_score")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  company           Company?         @relation(fields: [companyId], references: [id])
  financialReport   FinancialReport? @relation(fields: [financialReportId], references: [id])
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([year])
  @@index([companyId, year])
  @@map("ai_reports")
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  plan      SubscriptionPlan   @default(FREE)
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now()) @map("start_date")
  endDate   DateTime?          @map("end_date")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  transactions Transaction[]
  logs         SubscriptionLog[]
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Transaction {
  id                  String        @id @default(cuid())
  userId              String        @map("user_id")
  subscriptionId      String?       @map("subscription_id")
  provider            String
  plan                SubscriptionPlan
  amount              Float
  currency            String        @default("NPR")
  status              String        @default("PENDING")
  localReference      String        @unique @map("local_reference")
  externalReference   String?       @unique @map("external_reference")
  gatewayTransactionId String?      @map("gateway_transaction_id")
  signatureVerified   Boolean       @default(false) @map("signature_verified")
  fraudFlag           Boolean       @default(false) @map("fraud_flag")
  fraudReason         String?       @map("fraud_reason")
  gatewayRequest      Json?         @map("gateway_request")
  gatewayResponse     Json?         @map("gateway_response")
  verifiedAt          DateTime?     @map("verified_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at")
  subscriptionLogs    SubscriptionLog[]
  subscription        Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, status])
  @@index([subscriptionId])
  @@map("transactions")
}

model SubscriptionLog {
  id             String            @id @default(cuid())
  userId         String            @map("user_id")
  subscriptionId String?           @map("subscription_id")
  transactionId  String?           @map("transaction_id")
  action         String
  previousPlan   SubscriptionPlan? @map("previous_plan")
  nextPlan       SubscriptionPlan? @map("next_plan")
  status         String
  details        Json?
  createdAt      DateTime          @default(now()) @map("created_at")
  subscription   Subscription?     @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  transaction    Transaction?      @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([subscriptionId])
  @@index([transactionId])
  @@index([status])
  @@map("subscription_logs")
}

model Referral {
  id          String         @id @default(cuid())
  inviterId   String         @map("inviter_id")
  inviteeId   String         @unique @map("invitee_id")
  referralCode String        @map("referral_code")
  status      ReferralStatus @default(CONVERTED)
  convertedAt DateTime       @default(now()) @map("converted_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  invitee     User           @relation("ReferralInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviter     User           @relation("ReferralInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  rewards     Reward[]

  @@unique([inviterId, inviteeId])
  @@index([inviterId])
  @@index([referralCode])
  @@index([status])
  @@index([convertedAt])
  @@map("referrals")
}

model Reward {
  id            String       @id @default(cuid())
  userId        String       @map("user_id")
  referralId    String?      @map("referral_id")
  rewardType    String       @map("reward_type")
  premiumDays   Int          @default(0) @map("premium_days")
  triggerCount  Int          @map("trigger_count")
  status        RewardStatus @default(GRANTED)
  grantedAt     DateTime     @default(now()) @map("granted_at")
  expiresAt     DateTime?    @map("expires_at")
  metadata      Json?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  referral      Referral?    @relation(fields: [referralId], references: [id], onDelete: SetNull)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardType, triggerCount])
  @@index([userId])
  @@index([referralId])
  @@index([status])
  @@index([grantedAt])
  @@map("rewards")
}

model UsageTracking {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  featureKey String   @map("feature_key")
  period     String
  usageCount Int      @default(0) @map("usage_count")
  limit      Int?     @map("limit")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey, period])
  @@index([userId])
  @@index([featureKey])
  @@index([period])
  @@map("usage_tracking")
}

model FinancialProfile {
  id                        String                     @id @default(cuid())
  userId                    String                     @map("user_id")
  monthlyIncome             Float                      @map("monthly_income")
  monthlyExpenses           Float                      @map("monthly_expenses")
  currentSavings            Float                      @map("current_savings")
  riskTolerance             RiskTolerance              @map("risk_tolerance")
  investmentHorizonYears    Int                        @map("investment_horizon_years")
  financialGoal             FinancialGoal              @map("financial_goal")
  targetAmount              Float?                     @map("target_amount")
  targetDate                DateTime?                  @map("target_date")
  monthlyContribution       Float?                     @map("monthly_contribution")
  emergencyFundMonths       Int?                       @map("emergency_fund_months")
  insuranceCoverage         Boolean?                   @default(false) @map("insurance_coverage")
  dependentsCount           Int?                       @map("dependents_count")
  employmentStatus          String?                    @map("employment_status")
  annualIncomeGrowth        Float?                     @map("annual_income_growth")
  preferredInvestmentTypes  String[]                   @map("preferred_investment_types")
  investmentExperience      String?                    @map("investment_experience")
  liquidityPreference       String?                    @map("liquidity_preference")
  taxBracket                String?                    @map("tax_bracket")
  lastUpdated               DateTime                   @updatedAt @map("last_updated")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  financialGoals            FinancialGoalProfile[]
  user                      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  investmentRecommendations InvestmentRecommendation[]

  @@unique([userId, financialGoal])
  @@index([userId])
  @@index([userId, financialGoal])
  @@index([riskTolerance])
  @@index([investmentHorizonYears])
  @@index([financialGoal, targetDate])
  @@index([monthlyIncome])
  @@index([createdAt])
  @@index([lastUpdated])
  @@map("financial_profiles")
}

model InvestmentRecommendation {
  id                 String           @id @default(cuid())
  financialProfileId String           @map("financial_profile_id")
  investmentType     String           @map("investment_type")
  recommendationText String           @map("recommendation_text")
  riskLevel          String           @map("risk_level")
  expectedReturn     Float?           @map("expected_return")
  timeHorizon        Int?             @map("time_horizon")
  minimumInvestment  Float?           @map("minimum_investment")
  confidenceScore    Float?           @map("confidence_score")
  isActive           Boolean          @default(true) @map("is_active")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  financialProfile   FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)

  @@index([financialProfileId])
  @@index([investmentType])
  @@index([riskLevel])
  @@index([isActive])
  @@map("investment_recommendations")
}

model FinancialGoalProfile {
  id                  String           @id @default(cuid())
  financialProfileId  String           @map("financial_profile_id")
  goalType            String           @map("goal_type")
  goalName            String           @map("goal_name")
  targetAmount        Float            @map("target_amount")
  currentAmount       Float            @map("current_amount")
  targetDate          DateTime         @map("target_date")
  monthlyContribution Float            @map("monthly_contribution")
  priority            String           @map("priority")
  status              String           @map("status")
  progressPercentage  Float            @map("progress_percentage")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  financialProfile    FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)

  @@index([financialProfileId])
  @@index([goalType])
  @@index([status])
  @@index([targetDate])
  @@index([priority])
  @@map("financial_goal_profiles")
}

model TrainingData {
  id        String   @id @default(cuid())
  symbol    String
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Int
  source    String   @default("NEPSE")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
  @@index([version])
  @@map("training_data")
}

model MLModel {
  id           String      @id @default(cuid())
  modelId      String      @unique @map("model_id")
  name         String
  algorithm    String
  parameters   Json?
  trainingSize Int         @map("training_size")
  dataVersion  Int         @map("data_version")
  status       ModelStatus @default(TRAINED)
  metrics      Json?
  createdAt    DateTime    @default(now()) @map("created_at")
  deployedAt   DateTime?   @map("deployed_at")

  @@index([status])
  @@index([algorithm])
  @@map("ml_models")
}

model PipelineLog {
  id           String    @id @default(cuid())
  pipelineType String    @map("pipeline_type")
  status       String
  metrics      Json?
  details      Json?
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  @@index([pipelineType])
  @@index([status])
  @@index([startedAt])
  @@map("pipeline_logs")
}

model MLExperiment {
  id             String             @id @default(cuid())
  name           String
  description    String?
  type           ExperimentType     @default(HYPERPARAMETER)
  parameters     Json?
  datasetVersion String?            @map("dataset_version")
  modelType      String?            @map("model_type")
  status         ExperimentStatus   @default(RUNNING)
  results        Json?
  startTime      DateTime           @default(now()) @map("start_time")
  endTime        DateTime?          @map("end_time")
  metrics        ExperimentMetric[]
  predictions    PredictionLog[]

  @@index([type])
  @@index([status])
  @@index([startTime])
  @@map("ml_experiments")
}

model ExperimentMetric {
  id           String       @id @default(cuid())
  experimentId String       @map("experiment_id")
  epoch        Int?
  step         Int?
  metrics      Json
  timestamp    DateTime     @default(now())
  experiment   MLExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@index([timestamp])
  @@map("experiment_metrics")
}

model PredictionLog {
  id                 String        @id @default(cuid())
  experimentId       String?       @map("experiment_id")
  modelId            String?       @map("model_id")
  symbol             String
  predictedDirection String?       @map("predicted_direction")
  actualDirection    String?       @map("actual_direction")
  predictedPrice     Float?        @map("predicted_price")
  actualPrice        Float?        @map("actual_price")
  predictionError    Float?        @map("prediction_error")
  correct            Boolean
  predictionTime     DateTime      @default(now()) @map("prediction_time")
  features           Json?
  experiment         MLExperiment? @relation(fields: [experimentId], references: [id])

  @@index([modelId])
  @@index([symbol])
  @@index([predictionTime])
  @@map("prediction_logs")
}

model DatasetVersion {
  id          String   @id @default(cuid())
  name        String
  version     String
  description String?
  size        String?
  recordCount Int?     @map("record_count")
  features    String[] @default([])
  source      String?
  statistics  Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([name, version])
  @@index([name])
  @@map("dataset_versions")
}

model LoanProduct {
  id                      String   @id @default(cuid())
  bankName                String   @map("bank_name")
  loanType                String   @map("loan_type")
  interestRate            Float    @map("interest_rate")
  interestRateMax         Float?   @map("interest_rate_max")
  loanTerm                Int?     @map("loan_term")
  minimumIncome           Float?   @map("minimum_income")
  maxLoanAmount           Float?   @map("max_loan_amount")
  processingFee           Float?   @map("processing_fee")
  eligibilityRequirements String?  @map("eligibility_requirements")
  sourceUrl               String?  @map("source_url")
  lastUpdated             DateTime @map("last_updated")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@unique([bankName, loanType, sourceUrl, loanTerm], name: "provider_product_unique")
  @@map("loan_products")
}

model FiscalPeriod {
  id                 String              @id @default(cuid())
  symbol             String              @map("symbol")
  fiscalYear         String              @map("fiscal_year")
  quarter            String              @map("quarter")
  startDate          DateTime?           @map("start_date")
  endDate            DateTime?           @map("end_date")
  isAudited          Boolean             @default(false) @map("is_audited")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  financialRatio     FinancialRatio?
  financialStatement FinancialStatement?
  company            Company             @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  scrapingErrorLog   ScrapingErrorLog?

  @@unique([symbol, fiscalYear, quarter])
  @@index([symbol])
  @@index([fiscalYear])
  @@map("fiscal_periods")
}

model FinancialStatement {
  id                String       @id @default(cuid())
  periodId          String       @unique @map("period_id")
  revenue           Float
  operatingIncome   Float        @map("operating_income")
  netIncome         Float        @map("net_income")
  totalAssets       Float        @map("total_assets")
  totalLiabilities  Float        @map("total_liabilities")
  equity            Float
  eps               Float
  sharesOutstanding BigInt       @map("shares_outstanding")
  rawSourceUrl      String?      @map("raw_source_url")
  extractedAt       DateTime     @default(now()) @map("extracted_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  fiscalPeriod      FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId])
  @@map("financial_statements")
}

model FinancialRatio {
  id           String       @id @default(cuid())
  periodId     String       @unique @map("period_id")
  peRatio      Float?       @map("pe_ratio")
  pbRatio      Float?       @map("pb_ratio")
  roe          Float?
  roa          Float?
  debtToEquity Float?       @map("debt_to_equity")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  fiscalPeriod FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId])
  @@map("financial_ratios")
}

model ScrapingErrorLog {
  id            String        @id @default(cuid())
  periodId      String?       @unique @map("period_id")
  companySymbol String        @map("company_symbol")
  sourceUrl     String        @map("source_url")
  errorMessage  String        @map("error_message")
  errorStack    String?       @map("error_stack")
  retryCount    Int           @default(0) @map("retry_count")
  resolved      Boolean       @default(false)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  fiscalPeriod  FiscalPeriod? @relation(fields: [periodId], references: [id])

  @@index([companySymbol])
  @@index([resolved])
  @@map("scraping_error_logs")
}

model CorporateActionType {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  actions     CorporateAction[]

  @@map("corporate_action_types")
}

model CorporateAction {
  id               String              @id @default(cuid())
  companyId        String              @map("company_id")
  actionTypeId     String              @map("action_type_id")
  announcementDate DateTime            @map("announcement_date")
  exDate           DateTime?           @map("ex_date")
  recordDate       DateTime?           @map("record_date")
  ratio            String?
  sourceUrl        String?             @map("source_url")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  actionType       CorporateActionType @relation(fields: [actionTypeId], references: [id])
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dividend         Dividend?

  @@unique([companyId, actionTypeId, announcementDate])
  @@index([companyId])
  @@index([actionTypeId])
  @@map("corporate_actions")
}

model Dividend {
  id                  String           @id @default(cuid())
  companyId           String           @map("company_id")
  corporateActionId   String?          @unique @map("corporate_action_id")
  dividendType        String?          @map("dividend_type")
  amount              Float?           @map("amount")
  announcementDate    DateTime?        @map("announcement_date")
  exDate              DateTime?        @map("ex_date")
  fiscalYear          String           @map("fiscal_year")
  dividendPercentage  Float?           @map("dividend_percentage")
  dividendAmount      Float?           @map("dividend_amount")
  isBonus             Boolean          @default(false) @map("is_bonus")
  isCash              Boolean          @default(false) @map("is_cash")
  paymentDate         DateTime?        @map("payment_date")
  yieldAtAnnouncement Float?           @map("yield_at_announcement")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  company             Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  corporateAction     CorporateAction? @relation(fields: [corporateActionId], references: [id])

  @@index([companyId])
  @@index([fiscalYear])
  @@index([announcementDate])
  @@index([exDate])
  @@map("dividends")
}

model DividendHistory {
  id               String    @id @default(cuid())
  companyId        String    @map("company_id")
  symbol           String    @map("symbol")
  dividendType     String    @map("dividend_type")
  fiscalYear       String?   @map("fiscal_year")
  amount           Float?    @map("amount")
  percentage       Float?    @map("percentage")
  announcementDate DateTime? @map("announcement_date")
  exDate           DateTime? @map("ex_date")
  paymentDate      DateTime? @map("payment_date")
  source           String    @default("INTERNAL")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([announcementDate])
  @@index([exDate])
  @@index([paymentDate])
  @@index([companyId])
  @@index([symbol])
  @@index([companyId, announcementDate(sort: Desc)])
  @@map("dividend_history")
}

model DataQualityAnomaly {
  id          String    @id @default(cuid())
  companyId   String?   @map("company_id")
  symbol      String?
  dataset     String
  recordKey   String?   @map("record_key")
  reason      String
  details     Json?
  detectedAt  DateTime  @default(now()) @map("detected_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([dataset])
  @@index([symbol])
  @@index([detectedAt])
  @@index([companyId])
  @@map("data_quality_anomalies")
}

model DataQualityAuditLog {
  id          String    @id @default(cuid())
  companyId   String?   @map("company_id")
  symbol      String?
  dataset     String
  action      String
  status      String
  recordKey   String?   @map("record_key")
  details     Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([dataset])
  @@index([status])
  @@index([symbol])
  @@index([createdAt])
  @@index([companyId])
  @@map("data_quality_audit_logs")
}

model NewsArticle {
  id           String               @id @default(cuid())
  title        String
  content      String
  summary      String?
  publishedAt  DateTime             @map("published_at")
  sourceName   String               @map("source_name")
  sourceUrl    String               @unique @map("source_url")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  companyLinks ArticleCompanyLink[]
  sentiments   NewsSentiment[]

  @@index([publishedAt])
  @@index([sourceName])
  @@map("news_articles")
}

model ArticleCompanyLink {
  id        String      @id @default(cuid())
  articleId String      @map("article_id")
  companyId String      @map("company_id")
  createdAt DateTime    @default(now()) @map("created_at")
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([articleId, companyId])
  @@index([companyId])
  @@map("article_company_links")
}

model NewsSentiment {
  id              String                  @id @default(cuid())
  articleId       String                  @map("article_id")
  companyId       String                  @map("company_id")
  classification  SentimentClassification
  score           Float
  confidenceScore Float                   @map("confidence_score")
  explanation     String
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  article         NewsArticle             @relation(fields: [articleId], references: [id], onDelete: Cascade)
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([articleId, companyId])
  @@index([companyId])
  @@index([classification])
  @@map("news_sentiments")
}

model OptimizedPortfolio {
  id                   String                @id @default(cuid())
  userId               String                @map("user_id")
  expectedReturn       Float                 @map("expected_return")
  expectedVolatility   Float                 @map("expected_volatility")
  sharpeRatio          Float                 @map("sharpe_ratio")
  riskScore            Float                 @map("risk_score")
  diversificationScore Float                 @map("diversification_score")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations          PortfolioAllocation[]

  @@index([userId])
  @@map("optimized_portfolios")
}

model Portfolio {
  id        String          @id @default(cuid())
  userId    String          @unique @map("user_id")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @default(now()) @updatedAt @map("updated_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PortfolioItem[]

  @@index([userId])
  @@map("portfolios")
}

model PortfolioItem {
  id          String    @id @default(cuid())
  portfolioId String    @map("portfolio_id")
  stockId     String    @map("stock_id")
  quantity    Float
  buyPrice    Float     @map("buy_price")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stock       Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([stockId])
  @@unique([portfolioId, stockId])
  @@map("portfolio_items")
}

model PortfolioAllocation {
  id          String             @id @default(cuid())
  portfolioId String             @map("portfolio_id")
  companyId   String             @map("company_id")
  weight      Float
  sector      String?
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  portfolio   OptimizedPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, companyId])
  @@index([portfolioId])
  @@index([companyId])
  @@map("portfolio_allocations")
}

model CompanyDocument {
  id             String                   @id @default(cuid())
  companyId      String                   @map("company_id")
  title          String
  documentType   String                   @map("document_type")
  sourceUrl      String?                  @map("source_url")
  publishedAt    DateTime                 @map("published_at")
  parsedText     String?
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chunks         DocumentChunk[]
  extractedFacts ExtractedFinancialFact[]

  @@index([companyId])
  @@index([documentType])
  @@map("company_documents")
}

model Filing {
  id         String       @id @default(cuid())
  companyId  String       @map("company_id")
  fileUrl    String       @map("file_url")
  type       String
  uploadedAt DateTime     @default(now()) @map("uploaded_at")
  parsedText String?      @map("parsed_text")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chunks     FilingChunk[]

  @@index([companyId])
  @@index([type])
  @@index([uploadedAt])
  @@map("filings")
}

model FilingChunk {
  id         String   @id @default(cuid())
  filingId   String   @map("filing_id")
  pageNumber Int?     @map("page_number")
  chunkIndex Int      @map("chunk_index")
  content    String
  embedding  Json?
  createdAt  DateTime @default(now()) @map("created_at")
  filing     Filing   @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId])
  @@index([pageNumber])
  @@map("filing_chunks")
}

model DocumentChunk {
  id         String          @id @default(cuid())
  documentId String          @map("document_id")
  pageNumber Int?            @map("page_number")
  chunkIndex Int             @map("chunk_index")
  content    String
  tokenCount Int?            @map("token_count")
  document   CompanyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model ExtractedFinancialFact {
  id          String          @id @default(cuid())
  documentId  String          @map("document_id")
  companyId   String          @map("company_id")
  metricName  String          @map("metric_name")
  metricValue String          @map("metric_value")
  context     String?
  pageNumber  Int?            @map("page_number")
  createdAt   DateTime        @default(now()) @map("created_at")
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document    CompanyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([documentId])
  @@index([metricName])
  @@map("extracted_financial_facts")
}

model CompanyClassification {
  id              String   @id @default(cuid())
  companyId       String   @unique @map("company_id")
  sector          String
  strategy        String
  confidenceScore Float    @map("confidence_score")
  justification   String
  updatedAt       DateTime @updatedAt @map("updated_at")
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_classifications")
}

model ResearchQuery {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  queryText String           @map("query_text")
  status    String           @default("PENDING")
  createdAt DateTime         @default(now()) @map("created_at")
  answers   ResearchAnswer[]
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("research_queries")
}

model ResearchAnswer {
  id              String        @id @default(cuid())
  queryId         String        @map("query_id")
  answerText      String
  confidenceScore Float         @map("confidence_score")
  reasoningChain  Json?         @map("reasoning_chain")
  citations       Json
  createdAt       DateTime      @default(now()) @map("created_at")
  query           ResearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId])
  @@map("research_answers")
}

