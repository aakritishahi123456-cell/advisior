// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users table
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  phone        String?  
  dateOfBirth  DateTime? @map("date_of_birth")
  role         UserRole @default(FREE)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  loanSimulations LoanSimulation[]
  subscriptions   Subscription[]
  userUsage       UserUsage[]
  apiUsageLogs    ApiUsageLog[]
  aiReports AIReport[]
  financialProfiles FinancialProfile[]
  optimizedPortfolios OptimizedPortfolio[]
  researchQueries   ResearchQuery[]

  @@map("users")
}

// User Usage tracking table
model UserUsage {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  month        String   // YYYY-MM format
  reportCount  Int      @default(0) @map("report_count")
  requestCount Int      @default(0) @map("request_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId])
  @@index([month])
  @@map("user_usage")
}

// API Usage Logs table
model ApiUsageLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String
  method    String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("api_usage_logs")
}

// Companies table
model Company {
  id         String   @id @default(cuid())
  symbol     String   @unique
  name       String
  sector     String
  listedYear Int      @map("listed_year")
  listedDate DateTime? @map("listed_date")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  aiReports        AIReport[]
  nepsePrices      NepsePrice[]
  nepseFinancials  NepseFinancial[]
  fiscalPeriods    FiscalPeriod[]
  financialReports FinancialReport[]
  corporateActions CorporateAction[]
  dividends        Dividend[]
  articleLinks     ArticleCompanyLink[]
  newsSentiments   NewsSentiment[]
  portfolioAllocations PortfolioAllocation[]
  companyDocuments CompanyDocument[]
  extractedFacts   ExtractedFinancialFact[]
  companyClassification CompanyClassification?

  // Indexes
  @@index([symbol])
  @@index([sector])
  @@map("companies")
}

model NepsePrice {
  id        String   @id @default(cuid())
  symbol    String
  date      DateTime
  open      Float?   @map("open") 
  close     Float?   @map("close") 
  high      Float?   @map("high") 
  low       Float?   @map("low") 
  volume    BigInt?  @map("volume")
  source    String   @default("NEPSE")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
  @@map("prices")
}

model NepseFinancial {
  id            String   @id @default(cuid())
  symbol        String
  asOfDate      DateTime @map("as_of_date")
  eps           Float?   @map("eps") 
  peRatio       Float?   @map("pe_ratio") 
  marketCap     BigInt?  @map("market_cap")
  dividendYield Float?   @map("dividend_yield") 
  source        String   @default("NEPSE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, asOfDate])
  @@index([symbol])
  @@index([asOfDate])
  @@map("financials")
}

// Financial Reports table
model FinancialReport {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  year        Int
  revenue     Float    
  netProfit   Float    @map("net_profit") 
  totalAssets Float    @map("total_assets") 
  totalEquity Float    @map("total_equity") 
  totalDebt   Float    @map("total_debt") 
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  aiReports AIReport[]

  // Indexes
  @@index([companyId])
  @@index([year])
  @@index([companyId, year])
  @@map("financial_reports")
}

// Loan Simulations table
model LoanSimulation {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id") // Optional for MVP
  amount        Float     // Loan principal
  rate          Float     // Interest rate (annual percentage)
  tenure        Int      // Tenure in years
  emi           Float     // Equated Monthly Installment
  totalInterest Float    @map("total_interest") 
  totalPayment  Float    @map("total_payment") 
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Indexes for optimal query performance
  @@index([userId])                    // For user-specific queries
  @@index([createdAt])                 // For chronological queries
  @@index([userId, createdAt])         // For user's simulation history
  @@index([amount])                    // For amount-based searches
  @@index([rate])                      // For interest rate analysis
  @@index([tenure])                    // For tenure-based queries
  @@index([amount, rate, tenure])      // For exact match queries
  @@map("loan_simulations")
}

// AI Reports table
model AIReport {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  companyId    String?  @map("company_id")
  financialReportId String? @map("financial_report_id")
  year         Int?
  analysisText String   @map("analysis_text") @db.Text
  riskScore    Float    @map("risk_score") 
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  financialReport FinancialReport? @relation(fields: [financialReportId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([year])
  @@index([companyId, year])
  @@map("ai_reports")
}

// Subscriptions table
model Subscription {
  id        String            @id @default(cuid())
  userId    String            @map("user_id")
  plan      SubscriptionPlan  @default(FREE)
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime          @default(now()) @map("start_date")
  endDate   DateTime?         @map("end_date")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

// Enums
enum UserRole {
  FREE
  PRO
  INVESTOR
}

enum SubscriptionPlan {
  FREE
  PRO
  INVESTOR
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

// Financial Profile table
model FinancialProfile {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  monthlyIncome         Float    @map("monthly_income") 
  monthlyExpenses      Float    @map("monthly_expenses") 
  currentSavings       Float    @map("current_savings") 
  riskTolerance        RiskTolerance @map("risk_tolerance")
  investmentHorizonYears Int      @map("investment_horizon_years")
  financialGoal        FinancialGoal @map("financial_goal")
  targetAmount         Float?   @map("target_amount") 
  targetDate          DateTime? @map("target_date")
  monthlyContribution  Float?   @map("monthly_contribution") 
  emergencyFundMonths  Int?     @map("emergency_fund_months")
  insuranceCoverage    Boolean? @map("insurance_coverage") @default(false)
  dependentsCount     Int?     @map("dependents_count")
  employmentStatus     String?  @map("employment_status")
  annualIncomeGrowth   Float?   @map("annual_income_growth") 
  preferredInvestmentTypes String[] @map("preferred_investment_types")
  investmentExperience  String?  @map("investment_experience")
  liquidityPreference   String?  @map("liquidity_preference")
  taxBracket          String?  @map("tax_bracket")
  lastUpdated         DateTime @updatedAt @map("last_updated")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  investmentRecommendations InvestmentRecommendation[]
  financialGoals FinancialGoalProfile[]

  // Indexes for optimal query performance
  @@index([userId])                    // Primary user lookup
  @@index([userId, financialGoal])     // User goal queries
  @@index([riskTolerance])             // Risk-based filtering
  @@index([investmentHorizonYears])    // Horizon-based filtering
  @@index([financialGoal, targetDate])  // Goal-based queries
  @@index([monthlyIncome])             // Income-based queries
  @@index([createdAt])                 // Chronological queries
  @@index([lastUpdated])               // Update tracking
  @@unique([userId, financialGoal])     // One profile per goal type
  @@map("financial_profiles")
}

// Investment Recommendations based on financial profile
model InvestmentRecommendation {
  id                   String   @id @default(cuid())
  financialProfileId    String   @map("financial_profile_id")
  investmentType        String   @map("investment_type")
  recommendationText    String   @map("recommendation_text") @db.Text
  riskLevel            String   @map("risk_level")
  expectedReturn        Float?   @map("expected_return") 
  timeHorizon          Int?     @map("time_horizon")
  minimumInvestment    Float?   @map("minimum_investment") 
  confidenceScore      Float?   @map("confidence_score") 
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  financialProfile FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([financialProfileId])
  @@index([investmentType])
  @@index([riskLevel])
  @@index([isActive])
  @@map("investment_recommendations")
}

// Financial Goal Profiles for tracking multiple goals
model FinancialGoalProfile {
  id                   String   @id @default(cuid())
  financialProfileId    String   @map("financial_profile_id")
  goalType             String   @map("goal_type")
  goalName             String   @map("goal_name")
  targetAmount          Float    @map("target_amount") 
  currentAmount        Float    @map("current_amount") 
  targetDate           DateTime @map("target_date")
  monthlyContribution  Float    @map("monthly_contribution") 
  priority             String   @map("priority")
  status               String   @map("status")
  progressPercentage    Float    @map("progress_percentage") 
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  financialProfile FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([financialProfileId])
  @@index([goalType])
  @@index([status])
  @@index([targetDate])
  @@index([priority])
  @@map("financial_goal_profiles")
}

// Enums for Financial Profile
enum RiskTolerance {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

enum FinancialGoal {
  RETIREMENT
  HOUSE_PURCHASE
  EDUCATION_FUND
  WEALTH_GROWTH
  EMERGENCY_FUND
  DEBT_PAYOFF
  VACATION
  CAR_PURCHASE
  WEDDING
  BUSINESS_STARTUP
  INHERITANCE_PLANNING
  CHARITY_DONATION
}

// ============================================
// AUTO ML MODELS
// ============================================

// Training Data
model TrainingData {
  id          String   @id @default(cuid())
  symbol      String
  date        DateTime
  open        Float    
  high        Float    
  low         Float    
  close       Float    
  volume      Int
  source      String   @default("NEPSE")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
  @@index([version])
  @@map("training_data")
}

// ML Models
model MLModel {
  id            String    @id @default(cuid())
  modelId       String    @unique @map("model_id")
  name          String
  algorithm     String
  parameters    Json?
  trainingSize  Int       @map("training_size")
  dataVersion   Int       @map("data_version")
  status        ModelStatus @default(TRAINED)
  metrics       Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  deployedAt    DateTime? @map("deployed_at")

  @@index([status])
  @@index([algorithm])
  @@map("ml_models")
}

enum ModelStatus {
  TRAINING
  TRAINED
  TESTING
  PRODUCTION
  ARCHIVED
  DELETED
  FAILED
}

// Pipeline Execution Logs
model PipelineLog {
  id          String   @id @default(cuid())
  pipelineType String   @map("pipeline_type")
  status      String
  metrics     Json?
  details     Json?
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([pipelineType])
  @@index([status])
  @@index([startedAt])
  @@map("pipeline_logs")
}

// ============================================
// EXPERIMENT TRACKING
// ============================================

// ML Experiments
model MLExperiment {
  id            String    @id @default(cuid())
  name          String
  description   String?
  type          ExperimentType @default(HYPERPARAMETER)
  parameters    Json?
  datasetVersion String?  @map("dataset_version")
  modelType     String?  @map("model_type")
  status        ExperimentStatus @default(RUNNING)
  results       Json?
  startTime    DateTime  @default(now()) @map("start_time")
  endTime      DateTime? @map("end_time")
  
  metrics       ExperimentMetric[]
  predictions  PredictionLog[]

  @@index([type])
  @@index([status])
  @@index([startTime])
  @@map("ml_experiments")
}

enum ExperimentType {
  HYPERPARAMETER
  ARCHITECTURE
  FEATURE_ENGINEERING
  ENSEMBLE
}

enum ExperimentStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// Experiment Metrics
model ExperimentMetric {
  id            String   @id @default(cuid())
  experimentId  String   @map("experiment_id")
  epoch         Int?
  step          Int?
  metrics       Json
  timestamp     DateTime @default(now())

  experiment    MLExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
  @@index([timestamp])
  @@map("experiment_metrics")
}

// Prediction Logs
model PredictionLog {
  id                  String   @id @default(cuid())
  experimentId        String?  @map("experiment_id")
  modelId            String?  @map("model_id")
  symbol             String
  predictedDirection String?  @map("predicted_direction")
  actualDirection    String?  @map("actual_direction")
  predictedPrice    Float?   @map("predicted_price")
  actualPrice        Float?   @map("actual_price")
  predictionError    Float?   @map("prediction_error")
  correct            Boolean
  predictionTime     DateTime @default(now()) @map("prediction_time")
  features           Json?

  experiment          MLExperiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)

  @@index([modelId])
  @@index([symbol])
  @@index([predictionTime])
  @@map("prediction_logs")
}

// Dataset Versions
model DatasetVersion {
  id          String   @id @default(cuid())
  name        String
  version     String
  description String?
  size        String?
  recordCount Int?     @map("record_count")
  features    String[] @default([])
  source      String?
  statistics  Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([name, version])
  @@index([name])
  @@map("dataset_versions")
}

// Loan Products Scraped Data
model LoanProduct {
  id                      String   @id @default(cuid())
  bankName                String   @map("bank_name")
  loanType                String   @map("loan_type")
  interestRate            Float    @map("interest_rate")
  interestRateMax         Float?   @map("interest_rate_max")
  loanTerm                Int?     @map("loan_term")
  minimumIncome           Float?   @map("minimum_income")
  maxLoanAmount           Float?   @map("max_loan_amount")
  processingFee           Float?   @map("processing_fee")
  eligibilityRequirements String?  @map("eligibility_requirements")
  sourceUrl               String?  @map("source_url")
  lastUpdated             DateTime @map("last_updated")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@unique([bankName, loanType, sourceUrl, loanTerm], name: "provider_product_unique")
  @@map("loan_products")
}

// ----------------------------------------------------------------------
// Financial Fundamentals Scraper Schema Additions
// ----------------------------------------------------------------------

// Represents a distinct reporting period for a company
model FiscalPeriod {
  id          String   @id @default(cuid())
  symbol      String   @map("symbol") // Reference to Company symbol
  fiscalYear  String   @map("fiscal_year") // e.g., "2080/81"
  quarter     String   @map("quarter") // "Q1", "Q2", "Q3", "Q4", "Annual"
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  isAudited   Boolean  @default(false) @map("is_audited")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  company             Company              @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  financialStatement  FinancialStatement?
  financialRatio      FinancialRatio?
  scrapingErrorLog    ScrapingErrorLog?

  @@unique([symbol, fiscalYear, quarter]) // Prevent duplicate periods
  @@index([symbol])
  @@index([fiscalYear])
  @@map("fiscal_periods")
}

// Stores the core financial fundamentals
model FinancialStatement {
  id                String   @id @default(cuid())
  periodId          String   @unique @map("period_id")
  revenue           Float
  operatingIncome   Float    @map("operating_income")
  netIncome         Float    @map("net_income")
  totalAssets       Float    @map("total_assets")
  totalLiabilities  Float    @map("total_liabilities")
  equity            Float
  eps               Float
  sharesOutstanding BigInt   @map("shares_outstanding")
  
  // Scraper metadata
  rawSourceUrl      String?  @map("raw_source_url")
  extractedAt       DateTime @default(now()) @map("extracted_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  fiscalPeriod      FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId])
  @@map("financial_statements")
}

// Stores computed or extracted financial ratios
model FinancialRatio {
  id                String   @id @default(cuid())
  periodId          String   @unique @map("period_id")
  peRatio           Float?   @map("pe_ratio")
  pbRatio           Float?   @map("pb_ratio")
  roe               Float? // Return on Equity
  roa               Float? // Return on Assets
  debtToEquity      Float?   @map("debt_to_equity")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  fiscalPeriod      FiscalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId])
  @@map("financial_ratios")
}

// Logs errors encountered during scraping for observability
model ScrapingErrorLog {
  id                String   @id @default(cuid())
  periodId          String?  @unique @map("period_id")
  companySymbol     String   @map("company_symbol")
  sourceUrl         String   @map("source_url")
  errorMessage      String   @map("error_message")
  errorStack        String?  @map("error_stack")
  retryCount        Int      @default(0) @map("retry_count")
  resolved          Boolean  @default(false)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  fiscalPeriod      FiscalPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@index([companySymbol])
  @@index([resolved])
  @@map("scraping_error_logs")
}

// ----------------------------------------------------------------------
// Corporate Actions and Dividends Schema Additions
// ----------------------------------------------------------------------

model CorporateActionType {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  actions     CorporateAction[]

  @@map("corporate_action_types")
}

model CorporateAction {
  id               String              @id @default(cuid())
  companyId        String              @map("company_id")
  actionTypeId     String              @map("action_type_id")
  announcementDate DateTime            @map("announcement_date")
  exDate           DateTime?           @map("ex_date")
  recordDate       DateTime?           @map("record_date")
  ratio            String?
  sourceUrl        String?             @map("source_url")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actionType       CorporateActionType @relation(fields: [actionTypeId], references: [id], onDelete: Restrict)
  dividend         Dividend?

  @@unique([companyId, actionTypeId, announcementDate])
  @@index([companyId])
  @@index([actionTypeId])
  @@map("corporate_actions")
}

model Dividend {
  id                  String           @id @default(cuid())
  companyId           String           @map("company_id")
  corporateActionId   String?          @unique @map("corporate_action_id")
  fiscalYear          String           @map("fiscal_year")
  dividendPercentage  Float?           @map("dividend_percentage")
  dividendAmount      Float?           @map("dividend_amount")
  isBonus             Boolean          @default(false) @map("is_bonus")
  isCash              Boolean          @default(false) @map("is_cash")
  paymentDate         DateTime?        @map("payment_date")
  yieldAtAnnouncement Float?           @map("yield_at_announcement")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  company             Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  corporateAction     CorporateAction? @relation(fields: [corporateActionId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([fiscalYear])
  @@map("dividends")
}

// ----------------------------------------------------------------------
// News Sentiment AI Agent Schema Additions
// ----------------------------------------------------------------------

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  summary     String?  @db.Text
  publishedAt DateTime @map("published_at")
  sourceName  String   @map("source_name")
  sourceUrl   String   @unique @map("source_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  sentiments     NewsSentiment[]
  companyLinks   ArticleCompanyLink[]

  @@index([publishedAt])
  @@index([sourceName])
  @@map("news_articles")
}

model ArticleCompanyLink {
  id          String   @id @default(cuid())
  articleId   String   @map("article_id")
  companyId   String   @map("company_id")
  createdAt   DateTime @default(now()) @map("created_at")

  article     NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([articleId, companyId])
  @@index([companyId])
  @@map("article_company_links")
}

model NewsSentiment {
  id              String   @id @default(cuid())
  articleId       String   @map("article_id")
  companyId       String   @map("company_id")
  
  classification  SentimentClassification
  score           Float    // E.g., -1.0 to 1.0 polarity
  confidenceScore Float    @map("confidence_score") // 0.0 to 1.0
  explanation     String   @db.Text
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  article         NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([articleId, companyId])
  @@index([companyId])
  @@index([classification])
  @@map("news_sentiments")
}

enum SentimentClassification {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// ----------------------------------------------------------------------
// Portfolio Optimization Engine Schema Additions
// ----------------------------------------------------------------------

model OptimizedPortfolio {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  expectedReturn       Float    @map("expected_return")
  expectedVolatility   Float    @map("expected_volatility")
  sharpeRatio          Float    @map("sharpe_ratio")
  riskScore            Float    @map("risk_score")
  diversificationScore Float    @map("diversification_score")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations          PortfolioAllocation[]

  @@index([userId])
  @@map("optimized_portfolios")
}

model PortfolioAllocation {
  id           String             @id @default(cuid())
  portfolioId  String             @map("portfolio_id")
  companyId    String             @map("company_id")
  weight       Float
  sector       String?

  portfolio    OptimizedPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, companyId])
  @@index([portfolioId])
  @@index([companyId])
  @@map("portfolio_allocations")
}

// ----------------------------------------------------------------------
// FinSathi AI Research Agent Schema Additions
// ----------------------------------------------------------------------

model CompanyDocument {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  title       String
  documentType String  @map("document_type") // e.g., "ANNUAL_REPORT", "QUARTERLY_REPORT"
  sourceUrl   String?  @map("source_url")
  publishedAt DateTime @map("published_at")
  parsedText  String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chunks      DocumentChunk[]
  extractedFacts ExtractedFinancialFact[]

  @@index([companyId])
  @@index([documentType])
  @@map("company_documents")
}

model DocumentChunk {
  id             String   @id @default(cuid())
  documentId     String   @map("document_id")
  pageNumber     Int?     @map("page_number")
  chunkIndex     Int      @map("chunk_index")
  content        String   @db.Text
  tokenCount     Int?     @map("token_count")
  // Note: we store embeddings in a dedicated Vector DB like ChromaDB/Pinecone.
  // Alternatively, using pgvector, but here we keep the relation reference.
  
  document       CompanyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model ExtractedFinancialFact {
  id             String   @id @default(cuid())
  documentId     String   @map("document_id")
  companyId      String   @map("company_id")
  metricName     String   @map("metric_name")
  metricValue    String   @map("metric_value")
  context        String?  @db.Text
  pageNumber     Int?     @map("page_number")
  createdAt      DateTime @default(now()) @map("created_at")

  document       CompanyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([documentId])
  @@index([metricName])
  @@map("extracted_financial_facts")
}

model CompanyClassification {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  sector         String
  strategy       String
  confidenceScore Float   @map("confidence_score")
  justification  String   @db.Text
  updatedAt      DateTime @updatedAt @map("updated_at")

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
  @@map("company_classifications")
}

model ResearchQuery {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  queryText      String   @map("query_text") @db.Text
  status         String   @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt      DateTime @default(now()) @map("created_at")
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers        ResearchAnswer[]

  @@index([userId])
  @@map("research_queries")
}

model ResearchAnswer {
  id             String   @id @default(cuid())
  queryId        String   @map("query_id")
  answerText     String   @db.Text
  confidenceScore Float   @map("confidence_score")
  reasoningChain Json?    @map("reasoning_chain") // To store the explainable AI steps
  citations      Json     // Array of references: { documentId, pageNumber, snippet }
  createdAt      DateTime @default(now()) @map("created_at")

  query          ResearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId])
  @@map("research_answers")
}
