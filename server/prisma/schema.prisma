  FREE
  PRO
  INVESTOR
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum ReferralStatus {
  CONVERTED
}

enum RewardStatus {
  GRANTED
}

enum RiskTolerance {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

enum FinancialGoal {
  RETIREMENT
  HOUSE_PURCHASE
  EDUCATION_FUND
  WEALTH_GROWTH
  EMERGENCY_FUND
  DEBT_PAYOFF
  VACATION
  CAR_PURCHASE
  WEDDING
  BUSINESS_STARTUP
  INHERITANCE_PLANNING
  CHARITY_DONATION
