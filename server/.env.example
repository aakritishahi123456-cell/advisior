# Database Configuration
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/finsathi?schema=public
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Server Configuration
NODE_ENV=development
PORT=3001
TRUST_PROXY=1
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Redis Configuration
REDIS_URL=redis://:change-me@localhost:6379
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="change-me"
REDIS_DB=0

# Email Configuration
EMAIL_FROM="noreply@finsathi.ai"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_REQUESTS=3
REGISTER_RATE_LIMIT_WINDOW_MS=3600000
REGISTER_RATE_LIMIT_MAX_REQUESTS=3

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_DESTINATION="uploads/"

# Logging Configuration
LOG_LEVEL="info"
LOG_DIR="logs"
LOG_SERVICE_NAME="finsathi-api"

# Subscription Configuration
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
KHALTI_SECRET_KEY=""
KHALTI_BASE_URL="https://dev.khalti.com/api/v2/epayment"
KHALTI_RETURN_URL="http://localhost:3000/payments/khalti/callback"
ESEWA_PRODUCT_CODE="EPAYTEST"
ESEWA_SECRET_KEY=""
ESEWA_FORM_URL="https://rc-epay.esewa.com.np/api/epay/main/v2/form"
ESEWA_STATUS_CHECK_URL="https://rc.esewa.com.np/api/epay/transaction/status/"
ESEWA_SUCCESS_URL="http://localhost:3000/payments/esewa/success"
ESEWA_FAILURE_URL="http://localhost:3000/payments/esewa/failure"
PAYMENT_TRANSACTION_TTL_MINUTES=60

# External API Configuration
NEPSE_API_URL="https://nepseapi.com.np"
FINANCIAL_DATA_API_KEY="your-api-key"
OPENAI_API_KEY=""
AI_PROVIDER="openai"
AI_CHAT_MODEL="gpt-4o-mini"
AI_EMBEDDING_MODEL="text-embedding-3-small"
LOCAL_LLM_BASE_URL="http://localhost:11434"
LOCAL_LLM_MODEL="llama3.1"
AI_MAX_INPUT_TOKENS=2000
AI_MAX_OUTPUT_TOKENS=1200
AI_RESPONSE_CACHE_ENABLED=true
AI_RESPONSE_CACHE_TTL_SECONDS=600
VECTOR_BACKEND="prisma"
START_HTTP_SERVER=true
START_BACKGROUND_WORKERS=true

# NEPSE Auto-Collector (official NEPSE “newweb” API)
NEPSE_COLLECTOR_ENABLED=true
NEPSE_BASE_URL="https://newweb.nepalstock.com/api/nots"
NEPSE_HTTP_TIMEOUT_MS=30000
# Default: 3:20 PM Nepal time, Sun-Thu (trading days). Bull repeat supports tz.
NEPSE_COLLECTOR_CRON="20 15 * * 0-4"
NEPSE_COLLECTOR_TZ="Asia/Kathmandu"
# Endpoint overrides (only change if NEPSE API paths change)
NEPSE_MARKET_OPEN_PATH="/nepse-data/market-open"
NEPSE_SECURITY_PATH="/security"
NEPSE_DAILY_TRADE_PATH="/securityDailyTradeStat/58"
NEPSE_LIVE_ENABLED=true
NEPSE_LIVE_INTERVAL_MS=60000
NEPSE_LIVE_TRADE_PATH="/securityDailyTradeStat/58"
NEPSE_LIVE_MAX_SPIKE_PERCENT=20

# Portfolio Recommendation Engine (Python)
PYTHON_BIN="python"
PYTHON_PORTFOLIO_ENGINE_PATH="C:\\path\\to\\repo\\server\\python\\portfolio_engine\\main.py"
PORTFOLIO_ENGINE_TIMEOUT_MS=15000

# Monitoring Configuration
SENTRY_DSN="your-sentry-dsn"
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE=0
METRICS_ENABLED=true
NEW_RELIC_LICENSE_KEY="your-newrelic-key"

# Analytics Configuration
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"
MIXPANEL_TOKEN="your-mixpanel-token"

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET="your-session-secret"

# Development Configuration
DEBUG=finsathi:*
ENABLE_SWAGGER=true
ENABLE_PROFILING=false
