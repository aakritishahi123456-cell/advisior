# Core
PORT=5050
NODE_ENV=production

# Postgres
DATABASE_URL=postgresql://postgres:password@db-host:5432/finsathi

# Redis
REDIS_URL=redis://redis-host:6379

# Queues
QUEUE_ENABLED=true

# Security
JWT_SECRET=change_me
JWT_REFRESH_SECRET=
JWT_ISSUER=finsathi-ai
ENFORCE_HTTPS=true
TRUST_PROXY=1
CORS_ORIGINS=https://your-frontend-domain.com
AUTH_ALLOW_REGISTER=false

# AI
OPENAI_API_KEY=

# News
NEWS_RSS_FEEDS=
NEWSAPI_KEY=
