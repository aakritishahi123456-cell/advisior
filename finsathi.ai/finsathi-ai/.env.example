# Core
PORT=5050
NODE_ENV=development

# Postgres (Prisma)
DATABASE_URL=postgresql://postgres:newpassword@localhost:5432/finsathi

# Redis (Queues / rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# Queues (BullMQ)
QUEUE_ENABLED=false
QUEUE_ATTEMPTS=5
QUEUE_BACKOFF_MS=2000
QUEUE_CONCURRENCY=2
DLQ_NAME=deadLetterQueue

# Scheduler (node-cron)
SCHEDULER_ENABLED=true
SCHEDULER_TZ=Asia/Kathmandu
MARKET_DATA_CRON=0 9 * * 0-4
NEPSE_COLLECTOR_ENABLED=true
NEPSE_COLLECTOR_CRON=*/5 * * * *
FIN_ANALYSIS_CRON=0 16 * * 0-4
PORTFOLIO_CRON=0 17 * * 0-4
INSIGHTS_CRON=0 18 * * 0-4
STRATEGY_CRON=30 18 * * 0-4
FUNDAMENTALS_CRON=30 2 * * 0-6
CORPORATE_ACTIONS_CRON=15 3 * * 0-6
NEWS_SENTIMENT_CRON=*/30 * * * *

# Optional unified orchestration run (runs full agent pipeline in order)
AUTONOMOUS_CYCLE_CRON=
AUTONOMOUS_CYCLE_CONTINUE_ON_ERROR=true
AUTONOMOUS_CYCLE_RUN_STRATEGY=true

# Financial analysis thresholds
UNDERVALUED_PE_MAX=15
UNDERVALUED_MIN_ROE=10
HIGH_GROWTH_REVENUE_PCT=20
HIGH_RISK_DEBT_TO_EQUITY=2
HIGH_RISK_DEBT_RATIO=70
FIN_ANALYSIS_LIMIT=500

# Portfolio intelligence
PORTFOLIO_RISK_TOLERANCE=moderate
PORTFOLIO_HORIZON_DAYS=180
PORTFOLIO_LOOKBACK_DAYS=180
PORTFOLIO_UNIVERSE_LIMIT=60
PORTFOLIO_MIN_OBSERVATIONS=60
PORTFOLIO_RF_ANNUAL=0.02
PORTFOLIO_ANOMALY_PENALTY_PCT=0.1
PORTFOLIO_STORE_RECOMMENDATION=true

# Strategy simulation / backtesting
STRATEGY_NAME=momentum
STRATEGY_START_DATE=
STRATEGY_END_DATE=
STRATEGY_UNIVERSE_LIMIT=60
STRATEGY_TOP_N=10
STRATEGY_LOOKBACK_DAYS=60
STRATEGY_REBALANCE=weekly
STRATEGY_FEE_BPS=10
STRATEGY_CURVE_TAIL_DAYS=30
STRATEGY_RF_ANNUAL=0.02

# AI / LLM
OPENAI_API_KEY=your_openai_api_key_here
INSIGHTS_LLM_MODEL=gpt-4.1-mini
INSIGHTS_LLM_MAX_TOKENS=700
INSIGHTS_TOP_N=10

# News ingestion
NEWS_RSS_FEEDS=
NEWSAPI_KEY=
NEWS_LOOKBACK_HOURS=24
NEWS_ANALYZE_LIMIT=150
NEWS_SENTIMENT_MODEL=gpt-4.1-mini

# Security / Auth
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=7d
JWT_ISSUER=finsathi-ai
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AUTH_ALLOW_REGISTER=false

# Rate limiting (Redis-backed if REDIS_URL is set, else in-memory)
API_RL_WINDOW_MS=60000
API_RL_MAX=300
AUTH_RL_WINDOW_MS=900000
AUTH_RL_MAX=30
LOGIN_RL_WINDOW_MS=900000
LOGIN_RL_MAX=8

# HTTPS / proxy
ENFORCE_HTTPS=false
TRUST_PROXY=
CORS_ORIGINS=*
CORS_CREDENTIALS=false
 
DATABASE_URL=postgresql://postgres:newpassword@localhost:5432/advisor
DATABASE_URL=postgresql://username:password@localhost:5432/finsathi
JWT_SECRET=your_jwt_secret_here
OPENAI_API_KEY=your_openai_api_key_here
NODE_ENV=development
PORT=3001
UPSTASH_REDIS_REST_URL="https://sensible-rattler-73575.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token_here"