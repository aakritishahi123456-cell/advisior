// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===============================
// NEPSE Warehouse (Core)
// ===============================

model Company {
  id         String   @id @default(cuid())
  symbol     String   @unique
  name       String
  sector     String?
  listedYear Int?
  sharesOutstanding BigInt? @map("shares_outstanding")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prices   StockPrice[]
  reports  FinancialReport[]
  metrics  FinancialMetric[]
  fundamentals CompanyFundamentals?
  corporateActions CorporateAction[]
  newsSentiments NewsSentiment[]

  @@map("companies")
}

enum CorporateActionType {
  DIVIDEND
  BONUS_SHARES
  RIGHTS_SHARES
  STOCK_SPLIT
  MERGER
}

enum SentimentLabel {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum OfficialDocumentType {
  ANNUAL_REPORT
  QUARTERLY_REPORT
  INVESTOR_PRESENTATION
  FINANCIAL_DISCLOSURE
  OTHER
}

model StockPrice {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  symbol    String
  date      DateTime

  open      Decimal? @db.Decimal(12, 2)
  high      Decimal? @db.Decimal(12, 2)
  low       Decimal? @db.Decimal(12, 2)
  close     Decimal? @db.Decimal(12, 2)
  volume    BigInt?
  source    String   @default("NEPSE")

  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
  @@map("stock_prices")
}

model MarketIndexDaily {
  id           String   @id @default(cuid())
  indexName    String   @map("index_name")
  date         DateTime
  value        Decimal  @db.Decimal(12, 4)
  change       Decimal? @db.Decimal(12, 4)
  percentChange Decimal? @map("percent_change") @db.Decimal(12, 4)
  source       String   @default("NEPSE")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([indexName, date])
  @@index([indexName])
  @@index([date])
  @@map("market_index_daily")
}

model PriceAnomaly {
  id          String   @id @default(cuid())
  symbol      String
  date        DateTime
  close       Decimal? @db.Decimal(12, 2)
  prevClose   Decimal? @map("prev_close") @db.Decimal(12, 2)
  percentChange Decimal? @map("percent_change") @db.Decimal(12, 4)
  thresholdPct Decimal  @map("threshold_pct") @db.Decimal(12, 4)
  reason      String
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
  @@map("price_anomalies")
}

model FinancialReport {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  fiscalYear Int     @map("fiscal_year")
  period     String? // e.g. "Q1", "FY"

  revenue   Decimal? @db.Decimal(15, 2)
  netProfit Decimal? @map("net_profit") @db.Decimal(15, 2)
  totalAssets Decimal? @map("total_assets") @db.Decimal(15, 2)
  totalEquity Decimal? @map("total_equity") @db.Decimal(15, 2)
  totalDebt  Decimal? @map("total_debt") @db.Decimal(15, 2)

  source    String   @default("NEPSE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([fiscalYear])
  @@index([companyId, fiscalYear])
  @@map("financial_reports")
}

model FinancialMetric {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  symbol    String
  asOfDate  DateTime @map("as_of_date")

  eps           Decimal? @db.Decimal(12, 4)
  peRatio       Decimal? @map("pe_ratio") @db.Decimal(12, 4)
  roe           Decimal? @db.Decimal(12, 4)
  debtRatio     Decimal? @map("debt_ratio") @db.Decimal(12, 4)
  debtToEquity  Decimal? @map("debt_to_equity") @db.Decimal(12, 4)
  revenueGrowth Decimal? @map("revenue_growth") @db.Decimal(12, 4)

  isUndervalued Boolean  @default(false) @map("is_undervalued")
  isHighGrowth  Boolean  @default(false) @map("is_high_growth")
  isHighRisk    Boolean  @default(false) @map("is_high_risk")

  signals       Json?    // thresholds + rationale for flags

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([symbol, asOfDate])
  @@index([symbol])
  @@index([asOfDate])
  @@map("financial_metrics")
}

model CompanyFundamentals {
  symbol String @id

  companyName  String?  @map("company_name")
  sector        String?
  eps           Decimal? @db.Decimal(12, 4)
  peRatio       Decimal? @map("pe_ratio") @db.Decimal(12, 4)
  bookValue     Decimal? @map("book_value") @db.Decimal(12, 4)
  roe           Decimal? @db.Decimal(12, 4)
  netProfit     Decimal? @map("net_profit") @db.Decimal(20, 2)
  revenue       Decimal? @db.Decimal(20, 2)
  dividendYield Decimal? @map("dividend_yield") @db.Decimal(12, 4)
  marketCap     Decimal? @map("market_cap") @db.Decimal(24, 2)

  lastUpdated DateTime @updatedAt @map("last_updated")

  company Company @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@map("company_fundamentals")
}

model CorporateAction {
  id     String @id @default(cuid())
  symbol String

  actionType CorporateActionType @map("action_type")

  announcementDate DateTime  @map("announcement_date")
  recordDate       DateTime? @map("record_date")
  paymentDate      DateTime? @map("payment_date")

  dividendPercentage Decimal? @map("dividend_percentage") @db.Decimal(12, 4)
  bonusPercentage    Decimal? @map("bonus_percentage") @db.Decimal(12, 4)
  rightsRatio        String?  @map("rights_ratio")

  description String?

  source    String? @default("SCRAPER")
  sourceUrl String? @map("source_url")
  raw       Json?

  // Stable key derived from normalized payload to prevent duplicates across sources/runs.
  dedupeKey String @unique @map("dedupe_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@index([symbol])
  @@index([announcementDate])
  @@index([actionType])
  @@map("corporate_actions")
}

model NewsArticle {
  id String @id @default(cuid())

  title  String
  source String
  url    String @unique

  publishedAt DateTime @map("published_at")
  content     String?  @db.Text

  raw Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sentiments NewsSentiment[]

  @@index([publishedAt])
  @@index([source])
  @@map("news_articles")
}

model NewsSentiment {
  id String @id @default(cuid())

  symbol    String
  articleId String @map("article_id")

  sentimentScore Decimal @map("sentiment_score") @db.Decimal(6, 4)
  sentimentLabel SentimentLabel @map("sentiment_label")
  confidenceScore Decimal? @map("confidence_score") @db.Decimal(6, 4)

  model String?
  raw   Json?

  createdAt DateTime @default(now()) @map("created_at")

  company Company     @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  article NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([symbol, articleId])
  @@index([symbol])
  @@index([articleId])
  @@index([sentimentLabel])
  @@map("news_sentiments")
}

model OfficialDocument {
  id String @id @default(cuid())

  symbol String
  docType OfficialDocumentType @map("doc_type")

  title String
  source String? // e.g. "NEPSE", "Company Website"
  sourceUrl String? @unique @map("source_url")

  localPath String @map("local_path")
  sha256    String @unique

  publishedAt DateTime? @map("published_at")
  collectedAt DateTime @default(now()) @map("collected_at")

  isOfficial Boolean @default(true) @map("is_official")
  raw Json?

  company Company @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  chunks  OfficialDocumentChunk[]

  @@index([symbol])
  @@index([docType])
  @@index([publishedAt])
  @@map("official_documents")
}

model OfficialDocumentChunk {
  id String @id @default(cuid())

  documentId String @map("document_id")
  chunkIndex Int    @map("chunk_index")
  pageNumber Int    @map("page_number")

  text String @db.Text
  snippet String? @db.Text
  embedding Json
  embeddingModel String? @map("embedding_model")

  createdAt DateTime @default(now()) @map("created_at")

  document OfficialDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([pageNumber])
  @@map("official_document_chunks")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id String @id @default(cuid())

  email        String @unique
  passwordHash String @map("password_hash")
  role         UserRole @default(USER)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  authEvents    AuthEvent[]

  @@map("users")
}

model RefreshToken {
  id String @id @default(cuid())

  userId String @map("user_id")
  tokenHash String @unique @map("token_hash")

  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  replacedByTokenId String? @map("replaced_by_token_id")

  createdAt DateTime @default(now()) @map("created_at")

  createdByIp String? @map("created_by_ip")
  createdByUserAgent String? @map("created_by_user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuthEvent {
  id String @id @default(cuid())

  userId String? @map("user_id")
  eventType String @map("event_type") // LOGIN_SUCCESS, LOGIN_FAIL, REFRESH_SUCCESS, REFRESH_FAIL, LOGOUT
  success Boolean @default(false)

  ip String?
  userAgent String? @map("user_agent")
  email String?
  details Json?

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("auth_events")
}

// ===============================
// AI Insights + Simulation
// ===============================

model InsightReport {
  id        String   @id @default(cuid())
  date      DateTime @unique
  summary   String
  details   Json?
  model     String?  // LLM model identifier (optional)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("insight_reports")
}

model BacktestRun {
  id          String   @id @default(cuid())
  strategy    String
  parameters  Json?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  performance Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([strategy])
  @@map("backtest_runs")
}

model PortfolioRecommendation {
  id           String   @id @default(cuid())
  riskTolerance String? @map("risk_tolerance")
  horizonDays   Int?    @map("horizon_days")
  allocation    Json    // [{symbol, weight, rationale}]
  metrics       Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("portfolio_recommendations")
}

// ===============================
// Agent Pipeline Observability
// ===============================

model PipelineLog {
  id           String   @id @default(cuid())
  pipelineType String   @map("pipeline_type")
  status       String
  metrics      Json?
  details      Json?
  startedAt    DateTime @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  @@index([pipelineType])
  @@index([status])
  @@index([startedAt])
  @@map("pipeline_logs")
}
