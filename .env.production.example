# FinSathi AI Production Environment Variables
# Copy this to .env.production and fill in the values

# Backend infrastructure
POSTGRES_USER=finsathi
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=finsathi
REDIS_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://finsathi:replace-with-a-long-random-password@postgres:5432/finsathi?schema=public
REDIS_URL=redis://:replace-with-a-long-random-password@redis:6379

# Application
NODE_ENV=production
SERVER_PORT=3001
HTTP_PORT=80
HTTPS_PORT=443
TRUST_PROXY=1
API_DOMAIN=https://api.finsathi.ai
FRONTEND_URL=https://your-vercel-app.vercel.app
CORS_ORIGIN=https://your-vercel-app.vercel.app,https://www.your-domain.com
LETSENCRYPT_EMAIL=ops@your-domain.com

# JWT
JWT_SECRET=replace-with-a-32-plus-character-secret

# Frontend public vars for Vercel
NEXT_PUBLIC_API_URL=https://api.finsathi.ai
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe (International Payments)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Khalti (Nepal)
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_MERCHANT_ID=your_khalti_merchant_id

# eSewa (Nepal)
ESEWA_MERCHANT_CODE=your_esewa_merchant_code
ESEWA_SECRET_KEY=your_esewa_secret_key

# ConnectIPS (Nepal)
CONNECTIPS_MERCHANT_ID=your_connectips_merchant_id
CONNECTIPS_SECRET_KEY=your_connectips_secret_key

# Grafana
GRAFANA_PASSWORD=your_secure_grafana_password

# Observability
LOG_LEVEL=info
LOG_DIR=/app/logs
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
METRICS_ENABLED=true

# API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5
LOGIN_RATE_LIMIT_MAX_REQUESTS=3
