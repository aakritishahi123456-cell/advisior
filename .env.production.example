# FinSathi AI Production Environment Variables
# Copy this to .env.production and fill in the values

# Database (Supabase session pooler)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-your-region.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Application
NODE_ENV=production
SERVER_PORT=3001
WEB_PORT=3000
HTTP_PORT=80
HTTPS_PORT=443

# JWT
JWT_SECRET=your_very_long_secure_jwt_secret_key_here

# Frontend URL
NEXT_PUBLIC_API_URL=https://api.finsathi.ai
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe (International Payments)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Khalti (Nepal)
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_MERCHANT_ID=your_khalti_merchant_id

# eSewa (Nepal)
ESEWA_MERCHANT_CODE=your_esewa_merchant_code
ESEWA_SECRET_KEY=your_esewa_secret_key

# ConnectIPS (Nepal)
CONNECTIPS_MERCHANT_ID=your_connectips_merchant_id
CONNECTIPS_SECRET_KEY=your_connectips_secret_key

# Grafana
GRAFANA_PASSWORD=your_secure_grafana_password

# Redis (optional - will use internal if not set)
# REDIS_URL=redis://redis:6379
